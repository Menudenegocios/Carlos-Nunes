
<IfModule mod_rewrite.c>
  RewriteEngine On
  
  # Impede a listagem de diretórios
  Options -Indexes

  # Fallback para rotas SPA (Single Page Application)
  RewriteEngine On
RewriteBase /
RewriteRule ^index\.html$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.html [L]
</IfModule>
